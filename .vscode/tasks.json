{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build and Sign",
      "type": "shell",
      "command": "go build -gcflags \"all=-N -l\" -o the-moment . && codesign --force --sign - the-moment",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": "$go"
    },
    {
      "label": "Build, Sign, and Start Spoolman",
      "dependsOn": ["Build and Sign", "Start Spoolman"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Start Spoolman",
      "type": "shell",
      "command": "docker compose up -d spoolman",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Stop Spoolman",
      "type": "shell",
      "command": "docker compose stop spoolman",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: Build Dev Image",
      "type": "shell",
      "command": "docker build -t the-moment:local . && docker image prune -f",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "Docker: Start Dev Stack",
      "type": "shell",
      "command": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Docker: Build and Restart Dev Stack",
      "type": "shell",
      "command": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build && docker image prune -f",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "Docker: Stop Dev Stack",
      "type": "shell",
      "command": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Docker: Logs",
      "type": "shell",
      "command": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f the-moment",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    }
  ]
}
