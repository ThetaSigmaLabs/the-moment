# Copy this file to .env and adjust values for your environment.
# .env is gitignored — never commit it.

# ─── Ports ────────────────────────────────────────────────────────────────────

# Port The Moment listens on (host-side)
THE_MOMENT_PORT=5001

# Port Spoolman listens on (host-side)
SPOOLMAN_PORT=5002

# ─── Data directories (host paths) ───────────────────────────────────────────
#
# Both services store their databases in directories on the host filesystem
# (bind mounts), NOT in anonymous Docker volumes. This makes backups simple:
#   cp -r ./the-moment-data ./the-moment-data.bak
#   cp -r ./spoolman-data ./spoolman-data.bak
#
# Paths can be relative (resolved from the directory containing docker-compose.yml)
# or absolute (e.g. /mnt/nas/spoolman-data).
#
# The directories are created automatically by Docker on first run if they
# do not already exist.

# Host path for The Moment's SQLite database and config files.
THE_MOMENT_DB_PATH=./the-moment-data

# Host path for Spoolman's SQLite database.
SPOOLMAN_DB_PATH=./spoolman-data

# ─── Backups ──────────────────────────────────────────────────────────────────
#
# Directory where `make backup` writes timestamped archives.
# Point this at a network share or a path your backup agent already monitors.
# Archives are named: backup-YYYYMMDD-HHMMSS.tar.gz
# Restore with: make restore BACKUP=./backups/backup-YYYYMMDD-HHMMSS.tar.gz

BACKUP_DIR=./backups

# ─── Bambu printer debug logging ─────────────────────────────────────────────
#
# Set to 1 to enable verbose Bambu MQTT debug logging.
# Logs raw MQTT payloads, TLS handshake outcome, parsed status, and state
# machine transitions. Use this to capture a transcript when connecting a
# Bambu printer for the first time so any integration issues can be diagnosed.
#
# Collect logs with:  docker logs the-moment 2>&1 | grep "BAMBU"
#
# BAMBU_DEBUG=0
